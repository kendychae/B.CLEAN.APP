rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isImageFile() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isUnderSizeLimit() {
      return request.resource.size < 10 * 1024 * 1024; // 10MB
    }
    
    // Job photos
    match /jobs/{jobId}/{photo} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImageFile() && isUnderSizeLimit();
      allow delete: if isSignedIn();
    }
    
    // Profile photos
    match /profiles/{userId}/{photo} {
      allow read: if true; // Public read
      allow write: if isSignedIn() && 
                     request.auth.uid == userId && 
                     isImageFile() && 
                     isUnderSizeLimit();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Invoice PDFs
    match /invoices/{invoiceId}/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
