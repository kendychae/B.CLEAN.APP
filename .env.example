# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Google Maps
GOOGLE_MAPS_API_KEY_IOS=your_ios_google_maps_api_key
GOOGLE_MAPS_API_KEY_ANDROID=your_android_google_maps_api_key

# AdMob (optional — leave blank to ship the app with ads disabled)
# Format: ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY (app ID, with ~)
ADMOB_APP_ID_IOS=
ADMOB_APP_ID_ANDROID=
# Format: ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY (unit ID, with /)
ADMOB_BANNER_ID_IOS=
ADMOB_BANNER_ID_ANDROID=

# EAS
EAS_PROJECT_ID=your-eas-project-id-uuid

# App Configuration
APP_ENV=development
API_URL=https://your-cloud-functions-url.cloudfunctions.net
